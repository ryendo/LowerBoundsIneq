function test_Algorithm2_VerifyOmegaUp_debug()
% Debug test for Algorithm2_VerifyOmegaUp
% Save as: test_Algorithm2_VerifyOmegaUp_debug.m
%
% Purpose:
%   Identify exactly which block throws an error.
%
% Notes:
%   - Replace the parameters in Section 0 with your actual values.
%   - This test first checks suspicious expressions one by one.
%   - Then it runs the full function and prints the error stack.

    clc;
    fprintf('============================================================\n');
    fprintf('DEBUG TEST: Algorithm2_VerifyOmegaUp\n');
    fprintf('============================================================\n\n');

    % ============================================================
    % 0. USER SETTINGS: replace these with your actual inputs
    % ============================================================
    conjecture_type = 'J1';
    eps_up   = 0.01;
    Nx       = 2;
    Ny       = 2;
    Ny_axis  = 2;
    N_spec   = 10;

    mesh_params = struct();
    mesh_params.N_LG = 8;
    mesh_params.N_rho = 8;
    mesh_params.fem_ord_LG = 2;
    mesh_params.save_intermediate = false;
    mesh_params.results_dir = 'results';

    fprintf('[Input summary]\n');
    disp(struct( ...
        'conjecture_type', conjecture_type, ...
        'eps_up', eps_up, ...
        'Nx', Nx, ...
        'Ny', Ny, ...
        'Ny_axis', Ny_axis, ...
        'N_spec', N_spec, ...
        'mesh_params', mesh_params));

    % ============================================================
    % 1. Basic type / printing test
    % ============================================================
    run_block('basic constants + fprintf', @() test_basic_block(conjecture_type, eps_up, Nx, Ny, Ny_axis, N_spec));

    % ============================================================
    % 2. Step (1-2) node generation test
    % ============================================================
    run_block('STEP (1-2): x_nodes / y_nodes generation', @() test_step12_nodes(eps_up, Nx, Ny));

    % ============================================================
    % 3. Step (1-3) suspicious linspace test
    % ============================================================
    run_block('STEP (1-3): linspace(y_min, y_top, Ny_axis+1)', @() test_step13_nodes(eps_up, Ny_axis));

    % ============================================================
    % 4. mesh_params extraction test
    % ============================================================
    run_block('mesh_params field extraction', @() test_mesh_params(mesh_params));

    % ============================================================
    % 5. Box / interval construction test
    % ============================================================
    run_block('interval box construction', @() test_interval_box(eps_up));

    % ============================================================
    % 6. Full function call
    % ============================================================
    run_block('FULL CALL: Algorithm2_VerifyOmegaUp', @() ...
        Algorithm2_VerifyOmegaUp(conjecture_type, eps_up, Nx, Ny, Ny_axis, N_spec, mesh_params));

    fprintf('\n============================================================\n');
    fprintf('DEBUG TEST FINISHED\n');
    fprintf('============================================================\n');
end


% -------------------------------------------------------------------------
function test_basic_block(conjecture_type, eps_up, Nx, Ny, Ny_axis, N_spec)
    global INTERVAL_MODE;
    if isempty(INTERVAL_MODE)
        INTERVAL_MODE = 1;
    end

    conjecture_type = char(conjecture_type);
    p0 = [I_intval('0.5'), sqrt(I_intval('3'))/2]; %#ok<NASGU>

    fprintf('Conjecture: %s\n', conjecture_type);
    fprintf('eps_up = %.17g\n', eps_up);
    fprintf('Nx=%d, Ny=%d, Ny_axis=%d, N_spec=%d\n', Nx, Ny, Ny_axis, N_spec);
    fprintf('INTERVAL_MODE = %d\n', INTERVAL_MODE);
end


% -------------------------------------------------------------------------
function test_step12_nodes(eps_rect, Nx, Ny)
    x0    = I_intval('0.5');
    y_top = sqrt(I_intval('3'))/2;

    x_nodes = x0    + eps_rect*(0:Nx)/Nx;
    y_nodes = y_top - eps_rect*(0:Ny)/Ny;

    fprintf('x_nodes created successfully.\n');
    disp(x_nodes);
    fprintf('y_nodes created successfully.\n');
    disp(y_nodes);
end


% -------------------------------------------------------------------------
function test_step13_nodes(eps_up, Ny_axis)
    y_top = sqrt(I_intval('3'))/2;
    y_min = y_top - eps_up;

    fprintf('Class of y_top : %s\n', class(y_top));
    fprintf('Class of y_min : %s\n', class(y_min));

    % This is the most suspicious line
    y_nodes = linspace(y_min, y_top, Ny_axis+1);

    fprintf('y_nodes created successfully.\n');
    disp(y_nodes);
end


% -------------------------------------------------------------------------
function test_mesh_params(mesh_params)
    if isfield(mesh_params, 'N_LG')
        N_LG = mesh_params.N_LG;
    elseif isfield(mesh_params, 'N_LG_points')
        N_LG = mesh_params.N_LG_points;
    else
        error('mesh_params must contain N_LG (or N_LG_points).');
    end

    if isfield(mesh_params, 'N_rho')
        N_rho = mesh_params.N_rho;
    else
        error('mesh_params must contain N_rho.');
    end

    if isfield(mesh_params, 'fem_ord_LG')
        fem_ord_LG = mesh_params.fem_ord_LG;
    elseif isfield(mesh_params, 'fem_ord_lg')
        fem_ord_LG = mesh_params.fem_ord_lg;
    else
        error('mesh_params must contain fem_ord_LG (or fem_ord_lg).');
    end

    fprintf('N_LG       = %g\n', N_LG);
    fprintf('N_rho      = %g\n', N_rho);
    fprintf('fem_ord_LG = %g\n', fem_ord_LG);
end


% -------------------------------------------------------------------------
function test_interval_box(eps_up)
    x0    = I_intval('0.5');
    y_top = sqrt(I_intval('3'))/2;

    x_lo = x0;
    x_hi = x0 + eps_up/2;
    y_hi = y_top;
    y_lo = y_top - eps_up/2;

    xI = I_hull(x_lo, x_hi);
    yI = I_hull(y_lo, y_hi);

    sI = xI.^2 + yI.^2;

    fprintf('xI:\n');
    disp(xI);
    fprintf('yI:\n');
    disp(yI);
    fprintf('xI^2 + yI^2:\n');
    disp(sI);
    fprintf('I_inf(sI) = %.17g\n', I_inf(sI));
    fprintf('I_sup(sI) = %.17g\n', I_sup(sI));
end


% -------------------------------------------------------------------------
function run_block(name, fhandle)
    fprintf('\n------------------------------------------------------------\n');
    fprintf('[TEST] %s\n', name);
    fprintf('------------------------------------------------------------\n');

    try
        out = cell(1, nargout(fhandle));
        [out{:}] = fhandle(); %#ok<NASGU>
        fprintf('[OK] %s\n', name);
    catch ME
        fprintf('[FAILED] %s\n', name);
        fprintf('Error message:\n%s\n', ME.message);

        if ~isempty(ME.stack)
            fprintf('\nStack trace:\n');
            for k = 1:numel(ME.stack)
                fprintf('  #%d  file: %s\n', k, ME.stack(k).file);
                fprintf('      name: %s\n', ME.stack(k).name);
                fprintf('      line: %d\n', ME.stack(k).line);
            end
        end
    end
end